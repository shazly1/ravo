# Copy this file to .env.local and fill in your values

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/ravo
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/ravo

# JWT secret - use a long random string (32+ chars)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Initial Super Admin (used only for seeding)
SEED_SUPER_ADMIN_EMAIL=superadmin@ravo.com
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_NAME=Super Admin
